PORT=8080
APP_ENV=development
DATA_DIR=./data

# Production must set these to long, randomly generated values. Never commit .env.
APP_SESSION_SECRET=
DOCTOR_PORTAL_CODE=

# Optional model integration. Without these values the product runs in deterministic rules mode.
# Any OpenAI-compatible endpoint supported by the CloudWeGo Eino OpenAI component can be used.
# CONSULTATION_AI_* is used by the doctor Copilot. HEALTH_AGENT_* remains compatible with the legacy API.
CONSULTATION_AI_API_KEY=
CONSULTATION_AI_MODEL=
HEALTH_AGENT_API_KEY=
HEALTH_AGENT_MODEL=
OPENAI_BASE_URL=
OPENAI_BY_AZURE=false
OPENAI_API_VERSION=
